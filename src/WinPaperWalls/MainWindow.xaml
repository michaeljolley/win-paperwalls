<Window
    x:Class="WinPaperWalls.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:WinPaperWalls.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="48"
              Padding="16,0">
            <TextBlock Text="PaperWalls"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="36" Spacing="4" MaxWidth="700">
                <!-- Header -->
                <TextBlock Text="PaperWalls" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

                <!-- Backgrounds Section -->
                <TextBlock Text="Backgrounds"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,8" />

                <!-- Rotation Interval -->
                <controls:SettingsCard
                    Header="Rotation interval"
                    Description="How often the wallpaper changes"
                    AutomationProperties.AutomationId="SettingsCardInterval">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE895;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ComboBox x:Name="IntervalComboBox"
                              MinWidth="200"
                              SelectedIndex="{x:Bind ViewModel.SelectedIntervalIndex, Mode=TwoWay}"
                              AutomationProperties.AutomationId="IntervalComboBox"
                              AutomationProperties.Name="Rotation interval" />
                </controls:SettingsCard>

                <!-- Wallpaper Style -->
                <controls:SettingsCard
                    Header="Wallpaper style"
                    Description="How images are displayed on your desktop"
                    AutomationProperties.AutomationId="SettingsCardStyle">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE91B;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ComboBox x:Name="StyleComboBox"
                              MinWidth="200"
                              SelectedIndex="{x:Bind ViewModel.SelectedStyleIndex, Mode=TwoWay}"
                              AutomationProperties.AutomationId="StyleComboBox"
                              AutomationProperties.Name="Wallpaper style" />
                </controls:SettingsCard>

                <!-- Topics -->
                <controls:SettingsCard
                    Header="Wallpaper topics"
                    Description="Search and add wallpaper collections"
                    AutomationProperties.AutomationId="SettingsCardTopics">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8B9;" />
                    </controls:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsTopicsLoading, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.IsTopicsLoading), Mode=OneWay}"
                                      Width="20" Height="20" />
                        <TextBlock Text="Loading..."
                                   Visibility="{x:Bind BoolToVisibility(ViewModel.IsTopicsLoading), Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </controls:SettingsCard>

                <!-- Topic error -->
                <InfoBar Severity="Error"
                         IsOpen="{x:Bind ViewModel.TopicsError, Mode=OneWay}"
                         IsClosable="False"
                         Title="Failed to load topics"
                         Message="Could not connect to GitHub."
                         Visibility="{x:Bind BoolToVisibility(ViewModel.TopicsError), Mode=OneWay}"
                         Margin="0,4,0,0" />

                <!-- Topic search and pills -->
                <StackPanel Visibility="{x:Bind BoolToVisibility(ViewModel.TopicsLoaded), Mode=OneWay}"
                            Spacing="8"
                            Margin="0,4,0,0">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox x:Name="TopicSearchBox"
                                        Grid.Column="0"
                                        PlaceholderText="Search topics to add..."
                                        QueryIcon="Find"
                                        ItemsSource="{x:Bind ViewModel.TopicSuggestions, Mode=OneWay}"
                                        TextChanged="TopicSearchBox_TextChanged"
                                        SuggestionChosen="TopicSearchBox_SuggestionChosen"
                                        AutomationProperties.AutomationId="TopicSearchBox"
                                        AutomationProperties.Name="Search wallpaper topics" />
                        <Button Grid.Column="1"
                                Content="Select all"
                                Command="{x:Bind ViewModel.SelectAllTopicsCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                AutomationProperties.AutomationId="SelectAllTopicsButton" />
                        <Button Grid.Column="2"
                                Content="Deselect all"
                                Command="{x:Bind ViewModel.DeselectAllTopicsCommand}"
                                AutomationProperties.AutomationId="DeselectAllTopicsButton" />
                    </Grid>

                    <!-- Selected topic pills -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.SelectedTopics, Mode=OneWay}"
                                   AutomationProperties.AutomationId="SelectedTopicsList"
                                   AutomationProperties.Name="Selected wallpaper topics">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="120" MinItemHeight="32"
                                               MinRowSpacing="4" MinColumnSpacing="4"
                                               ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:TopicItemViewModel">
                                <Border CornerRadius="16"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Padding="12,0,4,0"
                                        Height="32">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                        <Button Command="{x:Bind RemoveCommand}"
                                                Padding="4"
                                                Width="24" Height="24"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                AutomationProperties.Name="Remove topic">
                                            <FontIcon Glyph="&#xE711;" FontSize="10" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Start with Windows -->
                <controls:SettingsCard
                    Header="Start with Windows"
                    Description="Launch PaperWalls automatically at login"
                    AutomationProperties.AutomationId="SettingsCardStartup">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7E8;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"
                                  AutomationProperties.AutomationId="StartWithWindowsToggle"
                                  AutomationProperties.Name="Start with Windows" />
                </controls:SettingsCard>

                <!-- Diagnostics Section -->
                <TextBlock Text="Diagnostics"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,24,0,8" />

                <!-- Cache Status -->
                <controls:SettingsCard
                    Header="Cache"
                    Description="{x:Bind ViewModel.CacheSizeText, Mode=OneWay}"
                    AutomationProperties.AutomationId="SettingsCardCache">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE74D;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button Content="Clear cache"
                            Command="{x:Bind ViewModel.ClearCacheCommand}"
                            AutomationProperties.AutomationId="ClearCacheButton"
                            AutomationProperties.Name="Clear wallpaper cache" />
                </controls:SettingsCard>

                <!-- Cache Max Size -->
                <controls:SettingsCard
                    Header="Maximum cache size"
                    Description="Oldest images are removed when the cache exceeds this limit"
                    AutomationProperties.AutomationId="SettingsCardCacheMax">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEDA2;" />
                    </controls:SettingsCard.HeaderIcon>
                    <NumberBox Value="{x:Bind ViewModel.CacheMaxMB, Mode=TwoWay}"
                               Minimum="100"
                               Maximum="2000"
                               SpinButtonPlacementMode="Inline"
                               MinWidth="160"
                               AutomationProperties.AutomationId="CacheMaxNumberBox"
                               AutomationProperties.Name="Maximum cache size in megabytes" />
                </controls:SettingsCard>

                <!-- Save -->
                <Button Content="Save settings"
                        Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="0,20,0,0"
                        AutomationProperties.AutomationId="SaveButton"
                        AutomationProperties.Name="Save settings" />

                <InfoBar x:Name="SaveSuccessBar"
                         Severity="Success"
                         IsOpen="{x:Bind ViewModel.SaveSuccessVisible, Mode=TwoWay}"
                         IsClosable="True"
                         Title="Settings saved"
                         Message="Your settings have been saved successfully."
                         Margin="0,4,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
